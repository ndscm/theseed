FROM ghcr.io/ndscm/ubuntu:latest

RUN userdel --remove ubuntu || true

RUN apt update
RUN apt install -y crun
RUN apt install -y curl
RUN apt install -y fuse-overlayfs
RUN apt install -y iputils-ping
RUN apt install -y lsb-release
RUN apt install -y podman
RUN apt install -y vim

COPY ./amadeus /opt/amadeus

COPY --chmod=0755 ./entrypoint.sh /opt/amadeus/entrypoint.sh

RUN useradd --uid 1000 --shell /usr/bin/bash --create-home amadeus

# # Rootless podman-in-podman support
#
# Nested rootless podman can't create a new user namespace (the outer container
# lacks CAP_SETUID/CAP_SETGID in the host userns, so newuidmap's write to
# uid_map is denied). These configs make the inner podman reuse the outer
# namespaces (userns=host) and use fuse-overlayfs instead of a real overlay
# mount.
#
# Run the outer container with `--privileged --device /dev/fuse`

COPY ./containers.conf /etc/containers/containers.conf
COPY --chown=amadeus:amadeus ./storage.conf /home/amadeus/.config/containers/storage.conf

# Prepopulate the playpen image into a shared, read-only additional image store
# instead of loading it into the amadeus user's store on every container start.
# The store is written by root, so force_mask=shared makes its files
# world-readable (with the original permissions preserved in an xattr and
# presented back by fuse-overlayfs) -- otherwise the unprivileged amadeus user
# could not read the root-owned layers. amadeus's storage.conf references this
# path via additionalimagestores above. The tar is bind-mounted for the load so
# its ~750MB never ends up baked into an image layer.
RUN --mount=type=bind,source=./playpen.tar,target=/tmp/playpen.tar \
  podman \
  --root /usr/local/share/containers/storage \
  --runroot /run/amadeus \
  --storage-driver overlay \
  --storage-opt overlay.mount_program=/usr/bin/fuse-overlayfs \
  --storage-opt overlay.force_mask=shared \
  load --input /tmp/playpen.tar \
  && chmod -R a+rX /usr/local/share/containers

ENV _CONTAINERS_USERNS_CONFIGURED=""
ENV BUILDAH_ISOLATION=chroot

VOLUME /playpen/home

# The container starts as root so the entrypoint can chown the mounted home; it
# drops to the amadeus user before running the workload.
WORKDIR /home/amadeus

ENTRYPOINT [ "/opt/amadeus/entrypoint.sh" ]

CMD [ "/opt/amadeus/amadeus-server" ]
