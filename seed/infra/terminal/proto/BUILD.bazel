load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@aspect_rules_ts//ts:proto.bzl", "ts_proto_library")
load("@protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_go//proto:def.bzl", "go_proto_library")
load("//seed/devprod/ndscm/starlark:defs.bzl", "nd_bootstrap")

package(default_visibility = ["//visibility:public"])

proto_library(
    name = "terminal_proto",
    srcs = ["terminal.proto"],
)

go_proto_library(
    name = "terminal_go_proto",
    importpath = "github.com/ndscm/theseed/seed/infra/terminal/proto/terminalpb",
    proto = ":terminal_proto",
)

ts_proto_library(
    name = "terminal_ts_proto",
    copy_files = False,
    node_modules = "//:node_modules",
    proto = ":terminal_proto",
)

npm_package(
    name = "terminal_ts_proto_pkg",
    srcs = [
        ":terminal_ts_proto",
    ],
)

alias(
    name = "pkg",  # Required by aspect_rules_js
    actual = ":terminal_ts_proto_pkg",
    visibility = ["//visibility:public"],
)

nd_bootstrap(
    dsts = [
        {
            "dst": "terminalpb",
            "dir": True,
            "srcs": [{
                "src": ":terminal_go_proto",
                "output_group": "go_generated_srcs",
            }],
        },
        {
            "dst": "terminal_pb.js",
            "srcs": [{
                "src": ":terminal_ts_proto",
            }],
        },
        {
            "dst": "terminal_pb.d.ts",
            "srcs": [{
                "src": ":terminal_ts_proto",
                "output_group": "types",
            }],
        },
    ],
)
