{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": [
    // sort
    "src/**/*"
  ],
  "exclude": [
    // default
    "node_modules",
    // ndscm
    "*.ndscm.ts",
    // dist
    "dist"
  ]
}
