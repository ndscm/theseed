{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "verbatimModuleSyntax": true
  },
  "include": [
    ".react-router/types/**/*",
    "**/.client/**/*",
    "**/.server/**/*",
    "**/*.ts",
    "**/*.tsx"
  ]
}
