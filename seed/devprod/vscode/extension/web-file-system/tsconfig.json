{
  // Generated by `npx --package typescript@5.9.3 tsc --init --rootDir "./src" --outdir "./dist" --module "commonjs" --target "es2022" --types node --lib "es2022" --verbatimModuleSyntax false`
  //
  // The web extension host loads an extension as a CommonJS module inside a
  // web worker: it fetches the file and runs it with `module` and `exports`
  // around it, resolving `require("vscode")` itself. So the output is
  // CommonJS, and everything the extension uses beyond the `vscode` module —
  // `fetch`, `atob` — is what a worker already has, which is why nothing is
  // bundled here and there is nothing else to import.
  //
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "commonjs",
    "target": "es2022",
    "types": ["vscode"],
    "lib": ["es2022", "dom"],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": [
    // sort
    "src/**/*"
  ],
  "exclude": [
    // default
    "node_modules",
    // ndscm
    "*.ndscm.ts",
    // dist
    "dist",
    // vscode
    ".vscode-test"
  ]
}
