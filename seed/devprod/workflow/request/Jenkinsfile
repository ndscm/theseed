pipeline {
  agent any
  parameters {
    // repository_url is kept for compatibility with callers that pass it through;
    // the Validate stage rejects anything other than the default.
    string name: 'repository_url', defaultValue: 'https://github.com/ndscm/theseed'
    string name: 'request_number'
    string name: 'request_branch', defaultValue: ''
    string name: 'request_commit_hash', defaultValue: ''
    string name: 'base_branch', defaultValue: ''
    string name: 'base_commit_hash', defaultValue: ''
  }
  stages {
    stage('Validate') {
      steps {
        echo "Repository URL: ${env.repository_url}"
        echo "Request number: ${env.request_number}"
        echo "Request branch: ${env.request_branch}"
        echo "Request commit hash: ${env.request_commit_hash}"
        echo "Base branch: ${env.base_branch}"
        echo "Base commit hash: ${env.base_commit_hash}"
        echo "Build URL: ${env.BUILD_URL}"
        script {
          if (env.repository_url != 'https://github.com/ndscm/theseed') {
            error "Unexpected repository_url: ${env.repository_url}"
          }
        }
        script {
          withCredentials([usernamePassword(credentialsId: 'ndscm', usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
            if (!env.request_branch) {
              env.request_branch = sh(
                script: '''#!/usr/bin/env bash
gh api /repos/ndscm/theseed/pulls/"$request_number" --jq '.head.ref'
''',
                returnStdout: true
              ).trim()
            }
            if (!env.request_commit_hash) {
              env.request_commit_hash = sh(
                script: '''#!/usr/bin/env bash
gh api /repos/ndscm/theseed/pulls/"$request_number" --jq '.head.sha'
''',
                returnStdout: true
              ).trim()
            }
            if (!env.base_branch) {
              env.base_branch = sh(
                script: '''#!/usr/bin/env bash
gh api /repos/ndscm/theseed/pulls/"$request_number" --jq '.base.ref'
''',
                returnStdout: true
              ).trim()
            }
            if (!env.base_commit_hash) {
              env.base_commit_hash = sh(
                script: '''#!/usr/bin/env bash
gh api /repos/ndscm/theseed/pulls/"$request_number" --jq '.base.sha'
''',
                returnStdout: true
              ).trim()
            }
            if (!env.request_branch || !env.request_commit_hash || !env.base_branch || !env.base_commit_hash) {
              error "Failed to resolve PR ${env.request_number}: missing one of request_branch, request_commit_hash, base_branch, base_commit_hash"
            }
            sh '''#!/usr/bin/env bash
gh api --method POST /repos/ndscm/theseed/statuses/"$request_commit_hash" \
  -f context=theseed/request \
  -f state=pending \
  -f description='Triggering per-commit workflows' \
  -f target_url="$BUILD_URL"
'''
          }
        }
      }
    }
    stage('Checkout') {
      steps {
        checkout scmGit(
          branches: [[name: "${env.request_commit_hash}"]],
          userRemoteConfigs: [[url: "${env.repository_url}.git", credentialsId: 'ndscm']],
        )
      }
    }
    stage('Start') {
      steps {
        script {
          def commits = sh(
            script: '''#!/usr/bin/env bash
git rev-list "$base_commit_hash".."$request_commit_hash"
''',
            returnStdout: true
          ).trim().split('\n')
          for (commit_hash in commits) {
            if (!commit_hash) {
              continue
            }
            withCredentials([usernamePassword(credentialsId: 'ndscm', usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
              withEnv(["COMMIT_HASH=${commit_hash}"]) {
                sh '''#!/usr/bin/env bash
gh api --method POST /repos/ndscm/theseed/statuses/"$COMMIT_HASH" \
  -f context=ndscm/check \
  -f state=pending \
  -f description='Scheduling check workflow'
'''
              }
            }
            build job: 'ndscm-check', wait: false, parameters: [
              string(name: 'repository_url', value: env.repository_url),
              string(name: 'branch', value: env.request_branch),
              string(name: 'commit_hash', value: commit_hash),
            ]
          }
        }
      }
    }
  }
  post {
    success {
      withCredentials([usernamePassword(credentialsId: 'ndscm', usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
        sh '''#!/usr/bin/env bash
gh api --method POST /repos/ndscm/theseed/statuses/"$request_commit_hash" \
  -f context=theseed/request \
  -f state=success \
  -f description='Triggered per-commit workflows' \
  -f target_url="$BUILD_URL"
'''
      }
    }
    failure {
      script {
        if (env.request_commit_hash) {
          withCredentials([usernamePassword(credentialsId: 'ndscm', usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
            sh '''#!/usr/bin/env bash
gh api --method POST /repos/ndscm/theseed/statuses/"$request_commit_hash" \
  -f context=theseed/request \
  -f state=failure \
  -f description='Request pipeline failed' \
  -f target_url="$BUILD_URL"
'''
          }
        }
      }
    }
  }
}
