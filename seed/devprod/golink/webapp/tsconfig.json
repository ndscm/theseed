{
  "compilerOptions": {
    // See: https://github.com/remix-run/react-router-templates/blob/7c24fbc5208d6de1606466625ed3358d21f7e775/default/tsconfig.json
    "lib": ["DOM", "DOM.iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    // sort
    ".react-router/types/**/*",
    "**/.client/**/*",
    "**/.server/**/*",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    // default
    "node_modules",
    // ndscm
    "*.ndscm.ts",
    // dist
    "dist"
  ]
}
