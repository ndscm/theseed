{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "declaration": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "verbatimModuleSyntax": true
  },
  "exclude": [
    "*.ndscm.ts", // exclude ndscm tson configs
    "dist"
  ]
}
