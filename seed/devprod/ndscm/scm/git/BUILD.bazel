    srcs = [
        "branch.go",
        "clone.go",
        "commit.go",
        "config.go",
        "monorepo.go",
        "provider.go",
        "rebase.go",
        "register.go",
        "remote.go",
        "status.go",
        "verify.go",
        "worktree.go",
    ],
    importpath = "github.com/ndscm/theseed/seed/devprod/ndscm/scm/git",
    deps = [
        "//seed/devprod/ndscm/scm",
        "//seed/infra/error/go/seederr",
        "//seed/infra/flag/go/seedflag",
        "//seed/infra/log/go/seedlog",
        "//seed/infra/shell/go/seedshell",
    ],
