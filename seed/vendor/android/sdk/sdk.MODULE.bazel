# Android Home

android_sdk_extension = use_extension("//seed/devprod/android/sdk:extension.bzl", "android_sdk_extension")
android_sdk_extension.configure(
    packages = [
        "build-tools;35.0.1",
        "cmake;4.1.2",
        "cmdline-tools;latest",
        "ndk;30.0.14904198",
        "platform-tools",
        "platforms;android-35",
    ],
    remove_files = [
        "ndk/30.0.14904198/sources/third_party/googletest/test/BUILD.bazel",
    ],
    repository_file = "//seed/devprod/android/sdk:repository2-3.xml",
    repository_url = "https://dl.google.com/android/repository/",
)
use_repo(
    android_sdk_extension,
    "android_sdk",
)

# Android SDK

bazel_dep(name = "rules_android", version = "0.7.2")
single_version_override(
    module_name = "rules_android",
    patch_strip = 1,
    patches = ["//seed/vendor/android/sdk:rules_android.patch"],
    version = "0.7.2",
)

remote_android_extensions = use_extension(
    "@rules_android//bzlmod_extensions:android_extensions.bzl",
    "remote_android_tools_extensions",
)
use_repo(remote_android_extensions, "android_tools")

android_sdk_repository_extension = use_extension("@rules_android//rules/android_sdk_repository:rule.bzl", "android_sdk_repository_extension")
android_sdk_repository_extension.configure(
    sdk = "@android_sdk//:files",
)
use_repo(android_sdk_repository_extension, "androidsdk")

# Android NDK

bazel_dep(name = "rules_android_ndk", version = "0.1.5")
single_version_override(
    module_name = "rules_android_ndk",
    patch_strip = 1,
    patches = ["//seed/vendor/android/sdk:rules_android_ndk.patch"],
    version = "0.1.5",
)

android_ndk_repository_extension = use_extension("@rules_android_ndk//:extension.bzl", "android_ndk_repository_extension")
android_ndk_repository_extension.configure(
    ndk = "@android_sdk//:ndk/30.0.14904198/files",
)
use_repo(android_ndk_repository_extension, "androidndk")

register_toolchains("@androidndk//:all")
