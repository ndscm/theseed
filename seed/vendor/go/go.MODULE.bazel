bazel_dep(name = "rules_go", version = "0.60.0")
bazel_dep(name = "gazelle", version = "0.50.0")

# Dependencies that required by both bazel and go mod
bazel_dep(name = "cel-spec", version = "0.25.1", repo_name = "dev_cel_expr")

go_sdk = use_extension("@rules_go//go:extensions.bzl", "go_sdk")
go_sdk.download(
    experiments = ["jsonv2"],
    version = "1.26.2",
)

go_deps = use_extension("@gazelle//:extensions.bzl", "go_deps")
go_deps.from_file(go_mod = "//:go.mod")

inject_repo(go_deps, "dev_cel_expr")

use_repo(
    go_deps,
    "com_connectrpc_connect",
    "com_connectrpc_grpchealth",
    "com_connectrpc_validate",
    "com_github_coder_websocket",
    "com_github_creack_pty",
    "com_github_go_acme_lego_v5",
    "com_github_google_uuid",
    "com_github_jackc_pgx_v5",
    "com_github_lib_pq",
    "com_github_rogpeppe_go_internal",
    "com_github_rs_cors",
    "com_github_soheilhy_cmux",
    "io_entgo_ent",
    "org_golang_google_grpc",
    "org_golang_google_protobuf",
    "org_golang_x_net",
    "org_golang_x_oauth2",
    "org_golang_x_sync",
)
