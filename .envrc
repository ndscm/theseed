# direnv config for the seed project.

dotenv seed/devprod/direnv/ndscm.env

# use PATH_add to prepend bin directories to PATH so dotslash-defined tools are available repo-wide.

PATH_add seed/vendor/age/bin
PATH_add seed/vendor/bazel/bin
PATH_add seed/vendor/buck/bin
PATH_add seed/vendor/claude/bin
PATH_add seed/vendor/crane/bin
PATH_add seed/vendor/docker/bin
PATH_add seed/vendor/github/bin
PATH_add seed/vendor/go/bin
PATH_add seed/vendor/jq/bin
PATH_add seed/vendor/kubernetes/bin
PATH_add seed/vendor/lego/bin
PATH_add seed/vendor/llvm/bin
PATH_add seed/vendor/ndscm/bin
PATH_add seed/vendor/node/bin
PATH_add seed/vendor/podman/bin
PATH_add seed/vendor/python/bin
PATH_add seed/vendor/rust/bin
PATH_add seed/vendor/shfmt/bin
PATH_add seed/vendor/uv/bin

if [[ "${OSTYPE}" == "linux"* ]]; then
  PATH_add contrib/vendor/perforce/bin
fi
