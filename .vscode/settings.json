{
  "clang-format.fallbackStyle": "Google",
  "clang-format.language.c.style": "Google",
  "clang-format.language.java.style": "Google",
  "clang-format.style": "Google",
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.formatOnSave": true,
  "editor.renderWhitespace": "all",
  "editor.detectIndentation": false,
  "files.associations": {
    ".bazelignore": "ignore",
    "*.conf": "plaintext",
    "*.svg": "html",
    "*.uvprojx": "plaintext",
    "repository*.xml": "plaintext"
  },
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/tmproots/**": true
  },
  "git.showActionButton": {
    "sync": false
  },
  "go.toolsManagement.autoUpdate": true,
  "isort.args": ["--profile", "black"],
  "prettier.documentSelectors": ["**/Jenkinsfile"],
  "prettier.proseWrap": "always",
  "prettier.semi": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "xml.format.enforceQuoteStyle": "preferred",
  "xml.format.splitAttributes": "splitNewLine",

  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[java]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[proto]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  }
}
