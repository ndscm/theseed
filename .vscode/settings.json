{
  "clang-format.fallbackStyle": "Google",
  "clang-format.language.c.style": "Google",
  "clang-format.language.java.style": "Google",
  "clang-format.style": "Google",
  "customFormatter.languages": [
    // sort
    "dockerfile",
    "groovy",
    "shellscript"
  ],
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.formatOnSave": true,
  "editor.renderWhitespace": "all",
  "editor.detectIndentation": false,
  "files.associations": {
    ".bazelignore": "ignore",
    ".buckconfig": "ini",
    ".buckroot": "ini",
    "*.conf": "plaintext",
    "*.svg": "html",
    "*.uvprojx": "plaintext",
    "BUCK": "starlark",
    "repository*.xml": "plaintext"
  },
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.watcherExclude": {
    "**/.cache/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.target/**": true,
    "**/.venv/**": true,
    "**/bazel-*/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/tmproots/**": true
  },
  "git.showActionButton": {
    "sync": false
  },
  "go.toolsManagement.autoUpdate": true,
  "gopls": {
    // encoding/json/v2 and encoding/json/jsontext are experimental in Go 1.26
    // (gated behind GOEXPERIMENT=jsonv2, which the Bazel toolchain enables) and
    // are dated to go1.27 in gopls' symbol table. The stdversion analyzer then
    // flags every v2 use against the go 1.26.2 directive in go.mod. Disable it;
    // the build is green and this resolves once we move to Go 1.27.
    "analyses": {
      "stdversion": false
    }
  },
  "isort.args": ["--profile", "black"],
  "prettier.prettierPath": "./node_modules/prettier",
  "prettier.documentSelectors": ["**/Jenkinsfile"],
  "prettier.proseWrap": "always",
  "prettier.semi": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "xml.format.enforceQuoteStyle": "preferred",
  "xml.format.splitAttributes": "splitNewLine",

  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ndscm.vscode-custom-formatter",
    "customFormatter.runAfterSave": "ndscm format {{FILE}}"
  },
  "[groovy]": {
    "editor.defaultFormatter": "ndscm.vscode-custom-formatter",
    "customFormatter.runAfterSave": "ndscm format {{FILE}}"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[java]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[proto]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[shellscript]": {
    "editor.defaultFormatter": "ndscm.vscode-custom-formatter",
    "customFormatter.runAfterSave": "ndscm format {{FILE}}"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  }
}
