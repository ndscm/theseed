// This tsconfig only covers ndscm config files. It exists purely for IDE
// type-checking and isn't used in any actual transpilation.
{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "paths": {
      // Root-relative imports. We prefix with @ because some tools
      // treat a bare // as an absolute path.
      "@//*": ["./*"]
    }
  },
  "include": [
    // ndscm
    "**/*.ndscm.ts"
  ],
  "exclude": [
    // default
    "node_modules",
    // bazel
    "bazel-*"
  ]
}
