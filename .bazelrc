common --@aspect_rules_ts//ts:skipLibCheck=honor_tsconfig
common --build_event_binary_file=.bep
common --experimental_isolated_extension_usages
common --incompatible_strict_action_env
common --remote_cache=http://cache.rbe.ndscm.com:22243 --remote_timeout=60


build --cxxopt=-std=c++17
build --host_cxxopt=-std=c++17
build --@boost.asio//:ssl=boringssl

# Java
build --java_language_version=21
build --java_runtime_version=remotejdk_21
build --tool_java_language_version=21
build --tool_java_runtime_version=remotejdk_21

# # Disable parse_headers to fix hedron_compile_commands with abseil-cpp
build --features=-parse_headers
build --host_features=-parse_headers

build --workspace_status_command=./seed/infra/buildinfo/bazel/generate-workspace-status.sh
